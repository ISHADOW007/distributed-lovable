pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(
            numToKeepStr: '20',
            artifactNumToKeepStr: '10'
        ))
    }

    environment {
        SERVICE_NAME = "account-service"
        IMAGE_NAME = "satyamgrao007/lovable-account-service"
        NAMESPACE = "lovable-core"
        MAVEN_OPTS = "-DskipTests"
    }

    stages {

        stage('Checkout Source') {
            steps {
                checkout scm
            }
        }

        stage('Verify Environment') {
            steps {
                sh '''
                    echo "========== Workspace =========="
                    pwd
                    ls -la

                    echo "========== Java =========="
                    java -version

                    echo "========== Git =========="
                    git --version

                    echo "========== Docker =========="
                    docker --version
                '''
            }
        }

        stage('Prepare Maven Wrapper') {
            steps {
                sh '''
                    chmod +x common-lib/mvnw
                    chmod +x account-service/mvnw
                '''
            }
        }

        stage('Build Common Library') {
            steps {
                dir('common-lib') {
                    sh './mvnw clean install -DskipTests'
                }
            }
        }

       stage('Run Unit Tests') {
           when {
               expression { false }
           }
           steps {
               echo "Skipping tests in CI"
           }
       }

        stage('Build Account Service') {
            steps {
                dir('account-service') {
                    sh "./mvnw clean package ${MAVEN_OPTS}"
                }
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts(
                    artifacts: 'account-service/target/*.jar',
                    fingerprint: true
                )
            }
        }

        stage('Build & Push Docker Image') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USERNAME',
                        passwordVariable: 'DOCKER_PASSWORD'
                    )
                ]) {

                    dir('account-service') {

                        sh """
                            ./mvnw jib:build \
                              -Djib.to.image=docker.io/${IMAGE_NAME}:${BUILD_NUMBER} \
                              -Djib.to.tags=latest \
                              -Djib.to.auth.username=${DOCKER_USERNAME} \
                              -Djib.to.auth.password=${DOCKER_PASSWORD}
                        """
                    }
                }
            }
        }

        /*
        stage('Deploy to Kubernetes') {
            steps {
                sh """
                    kubectl set image deployment/${SERVICE_NAME} \
                        ${SERVICE_NAME}=${IMAGE_NAME}:${BUILD_NUMBER} \
                        -n ${NAMESPACE}

                    kubectl rollout status deployment/${SERVICE_NAME} \
                        -n ${NAMESPACE}
                """
            }
        }
        */

    }

    post {

        success {
            echo "======================================"
            echo "BUILD SUCCESSFUL"
            echo "======================================"
        }

        failure {
            echo "======================================"
            echo "BUILD FAILED"
            echo "======================================"
        }

        always {
            cleanWs()
        }
    }
}