                */

            }

            post {

                success {

                    echo """

        ==========================================================

                        BUILD SUCCESSFUL

        ==========================================================

        Service : ${SERVICE_NAME}

        Image   : ${IMAGE_NAME}:${BUILD_NUMBER}

        ==========================================================

        """

                }

                failure {

                    echo """

        ==========================================================

                         BUILD FAILED

        ==========================================================

        Please check the Jenkins console output.

        ==========================================================

        """

                }

                always {

                    sh '''
                        docker logout || true
                    '''

                    deleteDir()

                }

            }

        }

