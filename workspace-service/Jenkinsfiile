pipeline {

    agent any

    options {
        timestamps()
        disableConcurrentBuilds()

        buildDiscarder(
            logRotator(
                numToKeepStr: '20',
                artifactNumToKeepStr: '10'
            )
        )
    }

    environment {

        // Service Information
        SERVICE_NAME = "workspace-service"

        // DockerHub Repository
        IMAGE_NAME = "satyamgrao007/lovable-workspace-service"

        // Kubernetes Namespace
        NAMESPACE = "lovable-core"

        // SonarQube Installation Name
        SONARQUBE_SERVER = "SonarQube"
    }

    stages {

        /**************************************************************
         * Checkout Source
         **************************************************************/
        stage('Checkout Source') {
            steps {
                checkout scm
            }
        }

        /**************************************************************
         * Prepare Maven Wrapper
         **************************************************************/
        stage('Prepare Maven Wrapper') {
            steps {
                sh '''
                    chmod +x common-lib/mvnw
                    chmod +x workspace-service/mvnw
                '''
            }
        }

        /**************************************************************
         * Verify Build Environment
         **************************************************************/
        stage('Verify Environment') {
            steps {
                sh '''
                    echo "========== JAVA =========="
                    java -version

                    echo ""
                    echo "========== MAVEN =========="
                    ./workspace-service/mvnw -version

                    echo ""
                    echo "========== GIT =========="
                    git --version

                    echo ""
                    echo "========== DOCKER =========="
                    docker --version

                    echo ""
                    echo "========== TRIVY =========="
                    trivy --version

                    echo ""
                    echo "========== DOCKER CONTAINERS =========="
                    docker ps
                '''
            }
        }

        /**************************************************************
         * Build Common Library
         **************************************************************/
        stage('Build Common Library') {
            steps {
                dir('common-lib') {
                    sh '''
                        ./mvnw clean install -DskipTests
                    '''
                }
            }
        }

        /**************************************************************
         * Build Service
         **************************************************************/
        stage('Build Service') {
            steps {
                dir('workspace-service') {
                    sh '''
                        ./mvnw clean verify -DskipTests
                    '''
                }
            }
        }

        /**************************************************************
         * SonarQube Analysis
         **************************************************************/
        stage('SonarQube Analysis') {
            steps {
                dir('workspace-service') {

                    withSonarQubeEnv("${SONARQUBE_SERVER}") {

                        sh '''
                            ./mvnw sonar:sonar \
                              -Dsonar.projectKey=workspace-service \
                              -Dsonar.projectName=workspace-service
                        '''

                    }
                }
            }
        }

        /**************************************************************
         * Quality Gate
         **************************************************************/
        stage('Quality Gate') {
            steps {

                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }

            }
        }

        /**************************************************************
         * Trivy Filesystem Scan
         **************************************************************/
