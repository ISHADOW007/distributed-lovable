         stage('Trivy Filesystem Scan') {

             steps {

                 dir('workspace-service') {

                     sh '''
                         echo "======================================"
                         echo "Scanning Source Code"
                         echo "======================================"

                         trivy fs \
                             --scanners vuln,misconfig,secret \
                             --severity HIGH,CRITICAL \
                             --exit-code 0 \
                             .

                         echo ""
                         echo "Filesystem Scan Completed"
                     '''

                 }

             }

         }

                /**************************************************************
                 * Build Docker Image (Local)
                 **************************************************************/
                stage('Build Docker Image') {

                    steps {

                        dir('workspace-service') {

                            sh '''
                                echo "======================================"
                                echo "Building Docker Image"
                                echo "======================================"

                                ./mvnw compile jib:dockerBuild \
                                  -DskipTests \
                                  -Djib.to.image=${IMAGE_NAME}:${BUILD_NUMBER}

                                docker images | grep ${SERVICE_NAME}

                                echo ""
                                echo "Docker Image Built Successfully"
                            '''

                        }

                    }

                }

                /**************************************************************
                 * Trivy Docker Image Scan
                 **************************************************************/
//                 stage('Trivy Docker Image Scan') {
//
//                     steps {
//
//                         sh '''
//                             echo "======================================"
//                             echo "Scanning Docker Image"
//                             echo "======================================"
//
//                             trivy image \
//                                 --severity HIGH,CRITICAL \
//                                 --exit-code 1 \
//                                 ${IMAGE_NAME}:${BUILD_NUMBER}
//
//                             echo ""
//                             echo "Docker Image Scan Passed"
//                         '''
//
//                     }
//
//                 }

               stage('Trivy Docker Image Scan') {

                   steps {

                       sh '''
                           echo "======================================"
                           echo "Scanning Docker Image"
                           echo "======================================"

                           trivy image \
                               --timeout 15m \
                               --scanners vuln \
                               --severity HIGH,CRITICAL \
                               --format json \
                               --output trivy-image-report.json \
                               --exit-code 0 \
                               ${IMAGE_NAME}:${BUILD_NUMBER}

                           echo ""
                           echo "Docker Image Scan Completed"
                       '''

                   }

                   post {
                       always {
                           archiveArtifacts artifacts: 'trivy-image-report.json'
                       }
                   }

               }

                /**************************************************************
                 * Docker Login
                 **************************************************************/
                stage('Docker Login') {

                    steps {

                        withCredentials([
                            usernamePassword(
                                credentialsId: 'dockerhub-creds',
                                usernameVariable: 'DOCKER_USERNAME',
                                passwordVariable: 'DOCKER_PASSWORD'
                            )
                        ]) {

                            sh '''
                                echo "$DOCKER_PASSWORD" | docker login \
                                    -u "$DOCKER_USERNAME" \
                                    --password-stdin
                            '''

                        }

                    }

                }

                /**************************************************************
                 * Push Docker Image
                 **************************************************************/
               stage('Push Docker Image') {

                   steps {

                       retry(3) {

                           sh '''
                               echo "======================================"
                               echo "Pushing Docker Image"
                               echo "======================================"

                               echo ""
                               echo "Docker Version"
                               docker version

                               echo ""
                               echo "Docker Info"
                               docker info

                               echo ""
                               echo "Local Images"
                               docker images | grep lovable-workspace-service || true

                               docker push ${IMAGE_NAME}:${BUILD_NUMBER}

                               docker tag ${IMAGE_NAME}:${BUILD_NUMBER} ${IMAGE_NAME}:latest

                               docker push ${IMAGE_NAME}:latest

                               echo ""
                               echo "Docker Image Successfully Pushed"
                           '''
                       }
                   }
               }
                /**************************************************************
                 * Deploy to Kubernetes
                 **************************************************************/

                /*
                stage('Deploy to Kubernetes') {

                    steps {

                        sh """

                            kubectl set image deployment/${SERVICE_NAME} \
